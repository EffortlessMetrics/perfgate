{
  "schema": "perfgate.compare.v1",
  "tool": {
    "name": "perfgate",
    "version": "0.2.0"
  },
  "bench": {
    "name": "cpu-budget-test",
    "command": [
      "echo",
      "hello"
    ],
    "repeat": 2,
    "warmup": 0
  },
  "baseline_ref": {
    "path": "test_output/baseline.json",
    "run_id": "baseline"
  },
  "current_ref": {
    "path": "test_output/current.json",
    "run_id": "current"
  },
  "budgets": {
    "wall_ms": {
      "threshold": 0.2,
      "warn_threshold": 0.18000000000000002,
      "direction": "lower"
    }
  },
  "deltas": {
    "wall_ms": {
      "baseline": 100.0,
      "current": 100.0,
      "ratio": 1.0,
      "pct": 0.0,
      "regression": 0.0,
      "status": "pass"
    }
  },
  "verdict": {
    "status": "pass",
    "counts": {
      "pass": 1,
      "warn": 0,
      "fail": 0
    },
    "reasons": []
  }
}