{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigFile",
  "description": "Top-level configuration file (`perfgate.toml`).\n\n# Examples\n\n```\nuse perfgate_types::ConfigFile;\n\nlet toml_str = r#\"\n[defaults]\nrepeat = 5\nthreshold = 0.20\n\n[[bench]]\nname = \"my-bench\"\ncommand = [\"echo\", \"hello\"]\n\"#;\n\nlet config: ConfigFile = toml::from_str(toml_str).unwrap();\nassert_eq!(config.benches.len(), 1);\nassert_eq!(config.benches[0].name, \"my-bench\");\nassert_eq!(config.defaults.repeat, Some(5));\n```",
  "type": "object",
  "properties": {
    "baseline_server": {
      "description": "Optional baseline server configuration for centralized baseline management.",
      "$ref": "#/$defs/BaselineServerConfig",
      "default": {
        "fallback_to_local": false
      }
    },
    "bench": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/BenchConfigFile"
      }
    },
    "defaults": {
      "$ref": "#/$defs/DefaultsConfig",
      "default": {}
    }
  },
  "$defs": {
    "BaselineServerConfig": {
      "description": "Configuration for the baseline server connection.\n\nWhen configured, the CLI can use a centralized baseline server\nfor storing and retrieving baselines instead of local files.\n\n# Examples\n\n```toml\n[baseline_server]\nurl = \"http://localhost:3000/api/v1\"\napi_key = \"pg_live_xxx\"\nproject = \"my-project\"\nfallback_to_local = true\n```",
      "type": "object",
      "properties": {
        "api_key": {
          "description": "API key for authentication.",
          "type": [
            "string",
            "null"
          ]
        },
        "fallback_to_local": {
          "description": "Fall back to local storage when server is unavailable.",
          "type": "boolean",
          "default": true
        },
        "project": {
          "description": "Project name for multi-tenancy.",
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "description": "URL of the baseline server (e.g., \"http://localhost:3000/api/v1\").",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "BenchConfigFile": {
      "type": "object",
      "properties": {
        "budgets": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "binary_bytes": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "cpu_ms": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "ctx_switches": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "energy_uj": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "io_read_bytes": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "io_write_bytes": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "max_rss_kb": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "network_packets": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "page_faults": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "throughput_per_s": {
              "$ref": "#/$defs/BudgetOverride"
            },
            "wall_ms": {
              "$ref": "#/$defs/BudgetOverride"
            }
          },
          "additionalProperties": false
        },
        "command": {
          "description": "argv vector (no shell parsing).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "metrics": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/Metric"
          }
        },
        "name": {
          "type": "string"
        },
        "repeat": {
          "description": "Number of measured samples (overrides defaults.repeat).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "timeout": {
          "description": "Duration string parseable by humantime, e.g. \"2s\".",
          "type": [
            "string",
            "null"
          ]
        },
        "warmup": {
          "description": "Warmup samples excluded from stats (overrides defaults.warmup).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "work": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "name",
        "command"
      ]
    },
    "BudgetOverride": {
      "type": "object",
      "properties": {
        "direction": {
          "anyOf": [
            {
              "$ref": "#/$defs/Direction"
            },
            {
              "type": "null"
            }
          ]
        },
        "noise_policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/NoisePolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "noise_threshold": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "statistic": {
          "anyOf": [
            {
              "$ref": "#/$defs/MetricStatistic"
            },
            {
              "type": "null"
            }
          ]
        },
        "threshold": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "warn_factor": {
          "description": "Warn fraction (warn_threshold = threshold * warn_factor).",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "DefaultsConfig": {
      "type": "object",
      "properties": {
        "baseline_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "baseline_pattern": {
          "description": "Optional baseline discovery pattern. Supports `{bench}` placeholder.\nExample: `baselines/{bench}.json`.",
          "type": [
            "string",
            "null"
          ]
        },
        "markdown_template": {
          "description": "Optional Handlebars template path for markdown comments.",
          "type": [
            "string",
            "null"
          ]
        },
        "noise_policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/NoisePolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "noise_threshold": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "out_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "repeat": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "threshold": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "warmup": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "warn_factor": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "Direction": {
      "type": "string",
      "enum": [
        "lower",
        "higher"
      ]
    },
    "Metric": {
      "type": "string",
      "enum": [
        "binary_bytes",
        "cpu_ms",
        "ctx_switches",
        "energy_uj",
        "io_read_bytes",
        "io_write_bytes",
        "max_rss_kb",
        "network_packets",
        "page_faults",
        "throughput_per_s",
        "wall_ms"
      ]
    },
    "MetricStatistic": {
      "type": "string",
      "enum": [
        "median",
        "p95"
      ]
    },
    "NoisePolicy": {
      "oneOf": [
        {
          "description": "No change to status based on noise.",
          "type": "string",
          "const": "ignore"
        },
        {
          "description": "Escalate Pass to Warn, and demote Fail to Warn.",
          "type": "string",
          "const": "warn"
        },
        {
          "description": "Demote Pass and Fail to Skip.",
          "type": "string",
          "const": "skip"
        }
      ]
    }
  }
}